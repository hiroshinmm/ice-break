<!DOCTYPE html>
<html lang="ja">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="UTF-8">
    <title>Daily Tech Briefing</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;500;700&display=swap');

        :root {
            --primary-bg: #f8fafc;
            --card-bg: #ffffff;
            --accent-blue: #3b82f6;
            --text-main: #1e293b;
            --text-sub: #64748b;
            --header-gradient: linear-gradient(135deg, #1e293b 0%, #334155 100%);
        }

        body {
            margin: 0;
            padding: 0;
            font-family: 'Outfit', sans-serif;
            background-color: var(--primary-bg);
            color: var(--text-main);
            line-height: 1.6;
        }

        header {
            background: var(--header-gradient);
            color: white;
            padding: 40px 20px;
            text-align: center;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
            margin-bottom: 40px;
        }

        header h1 {
            margin: 0;
            font-size: 32px;
            font-weight: 700;
            letter-spacing: -0.5px;
        }

        header p {
            margin: 10px 0 0 0;
            font-size: 16px;
            opacity: 0.8;
        }

        .container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 20px 60px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(600px, 1fr));
            gap: 30px;
        }

        @media (max-width: 768px) {
            .grid {
                grid-template-columns: 1fr;
            }
            .container {
                padding: 0 15px 40px;
            }
        }

        .card {
            background: var(--card-bg);
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
            display: flex;
            flex-direction: column;
            border: 1px solid rgba(0, 0, 0, 0.03);
            transition: transform 0.2s ease;
        }

        .card:hover {
            transform: translateY(-4px);
        }

        .card-image-section {
            width: 100%;
            height: 300px;
            background: #e2e8f0;
            overflow: hidden;
            position: relative;
        }

        .card-image-section img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .card-body {
            padding: 30px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }

        .card-category {
            font-size: 12px;
            font-weight: 700;
            color: var(--accent-blue);
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 12px;
        }

        .card-title {
            font-size: 22px;
            font-weight: 700;
            margin: 0 0 15px 0;
            line-height: 1.3;
        }

        .card-title a {
            color: inherit;
            text-decoration: none;
        }

        .card-title a:hover {
            color: var(--accent-blue);
        }

        .card-summary {
            font-size: 15px;
            color: var(--text-main);
            margin-bottom: 20px;
            padding-bottom: 20px;
            border-bottom: 1px solid #f1f5f9;
        }

        .card-insight-box {
            background: #f1f5f9;
            padding: 20px;
            border-radius: 12px;
            margin-bottom: 20px;
        }

        .card-insight-label {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-sub);
            text-transform: uppercase;
            margin-bottom: 8px;
            display: block;
        }

        .card-insight-content {
            font-size: 15px;
            color: #334155;
            font-style: italic;
        }

        .card-footer {
            margin-top: auto;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 13px;
            color: var(--text-sub);
        }

        .card-source a {
            color: var(--accent-blue);
            text-decoration: none;
            font-weight: 500;
        }

        .header-date {
            margin-top: 10px;
            font-size: 16px;
            opacity: 0.8;
        }

        .archive-selector {
            margin-top: 20px;
        }

        #archive-select {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.2);
            color: white;
            padding: 8px 16px;
            border-radius: 8px;
            font-family: inherit;
            font-size: 14px;
            cursor: pointer;
            outline: none;
            transition: background 0.2s;
        }

        #archive-select:hover {
            background: rgba(255, 255, 255, 0.2);
        }

        #archive-select option {
            background: #1e293b;
            color: white;
        }

    </style>
</head>

<body>

    <header>
        <h1>Daily Tech Briefing</h1>
        <div id="date-display" class="header-date">
            <%= new Date().toLocaleDateString('ja-JP', { timeZone: 'Asia/Tokyo' }) %> のテックニュース
        </div>
        <div class="archive-selector">
            <select id="archive-select" onchange="loadArchive(this.value)">
                <option value="">過去のブリーフィングを選択</option>
            </select>
        </div>
    </header>

    <div class="container">
        <div id="loading" style="display: none; text-align: center; padding: 40px; color: var(--text-sub);">
            Loading archives...
        </div>
        <div class="grid" id="insights-grid">
            <% for (const item of slides) { %>
                <div class="card">
                    <div class="card-image-section">
                        <% if (item.imageFile) { %>
                            <img src="images/<%= item.imageFile %>" alt="<%= item.title %>">
                        <% } else if (item.originalImageUrl) { %>
                            <img src="<%= item.originalImageUrl %>" alt="<%= item.title %>">
                        <% } else { %>
                            <img src="https://images.unsplash.com/photo-1485827404703-89b55fcc595e?auto=format&fit=crop&q=80&w=800" alt="Default Tech Image">
                        <% } %>
                    </div>
                    <div class="card-body">
                        <div class="card-category"><%= item.category %></div>
                        <h2 class="card-title">
                            <a href="<%= item.sourceUrl %>" target="_blank"><%= item.title %></a>
                        </h2>
                        <div class="card-summary">
                            <%= item.summary %>
                        </div>
                        <div class="card-insight-box">
                            <span class="card-insight-label">Technical Insight</span>
                            <div class="card-insight-content">
                                <%= item.insight %>
                            </div>
                        </div>
                        <div class="card-footer">
                            <div class="card-source">
                                Source: <a href="<%= item.sourceUrl %>" target="_blank"><%= item.sourceName %></a>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>

    <script>
        // アーカイブ一覧の取得とセレクトボックスの構築
        async function fetchManifest() {
            try {
                const res = await fetch('archives/manifest.json');
                if (!res.ok) return;
                const dates = await res.json();
                const select = document.getElementById('archive-select');
                dates.forEach(date => {
                    const option = document.createElement('option');
                    option.value = date;
                    option.textContent = date.replace(/-/g, '/');
                    select.appendChild(option);
                });

                // URLパラメータに日付があれば読み込む
                const params = new URLSearchParams(window.location.search);
                const queryDate = params.get('date');
                if (queryDate && dates.includes(queryDate)) {
                    select.value = queryDate;
                    loadArchive(queryDate);
                }
            } catch (e) { console.log('Archive manifest not found'); }
        }

        async function loadArchive(date) {
            if (!date) {
                window.location.href = window.location.pathname;
                return;
            }

            const loading = document.getElementById('loading');
            const grid = document.getElementById('insights-grid');
            loading.style.display = 'block';
            grid.style.opacity = '0.3';
            grid.style.pointerEvents = 'none';

            try {
                const [y, m, d] = date.split('-');
                const res = await fetch(`archives/${y}/${m}/${d}.json`);
                if (!res.ok) throw new Error('Archive not found');
                const data = await res.json();

                // grid の中身を生成
                renderGrid(data, date);
                
                // URLに反映 (ブラウザ履歴には残さない)
                const newUrl = `${window.location.pathname}?date=${date}`;
                window.history.replaceState({date}, date, newUrl);

                document.getElementById('date-display').textContent = `${date.replace(/-/g, '/')} のテックニュース`;
            } catch (e) {
                alert('アーカイブの読み込みに失敗しました。');
            } finally {
                loading.style.display = 'none';
                grid.style.opacity = '1';
                grid.style.pointerEvents = 'auto';
            }
        }

        function renderGrid(data, date) {
            const grid = document.getElementById('insights-grid');
            grid.innerHTML = '';
            
            Object.entries(data).forEach(([category, item]) => {
                if (!item) return;

                const card = document.createElement('div');
                card.className = 'card';
                
                // 画像判定 (アーカイブはオリジナルURL優先)
                let imgSrc = item.originalImageUrl || 'https://images.unsplash.com/photo-1485827404703-89b55fcc595e?auto=format&fit=crop&q=80&w=800';
                
                card.innerHTML = `
                    <div class="card-image-section">
                        <img src="${imgSrc}" alt="${item.title}">
                    </div>
                    <div class="card-body">
                        <div class="card-category">${category}</div>
                        <h2 class="card-title">
                            <a href="${item.sourceUrl}" target="_blank">${item.title}</a>
                        </h2>
                        <div class="card-summary">${item.summary}</div>
                        <div class="card-insight-box">
                            <span class="card-insight-label">Technical Insight</span>
                            <div class="card-insight-content">${item.insight}</div>
                        </div>
                        <div class="card-footer">
                            <div class="card-source">
                                Source: <a href="${item.sourceUrl}" target="_blank">${item.sourceName}</a>
                            </div>
                        </div>
                    </div>
                `;
                grid.appendChild(card);
            });
        }

        fetchManifest();
    </script>

</body>

</html>