<!DOCTYPE html>
<html lang="ja">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta charset="UTF-8">
    <title>Daily Tech Briefing</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;500;700&display=swap');

        body {
            margin: 0;
            padding: 0;
            font-family: 'Outfit', sans-serif;
            background-color: #f4f7f6;
            color: #333;
        }

        header {
            background: linear-gradient(135deg, #1A2980 0%, #26D0CE 100%);
            color: white;
            padding: 60px 40px;
            text-align: center;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            margin-bottom: 40px;
        }

        header h1 {
            margin: 0;
            font-size: 42px;
            font-weight: 700;
            letter-spacing: 1px;
        }

        header p {
            margin: 10px 0 0 0;
            font-size: 18px;
            opacity: 0.9;
        }

        .container {
            max-width: 1200px;
            /* Narrower container for 2 columns looks more balanced */
            margin: 0 auto;
            padding: 0 20px 60px;
        }

        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
            /* Larger min-width ensures 2 columns max on 1200px */
            gap: 40px;
            /* Larger gap for better separation */
        }

        @media (max-width: 480px) {
            .grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }

            header {
                padding: 40px 20px;
            }

            header h1 {
                font-size: 28px;
            }

            .container {
                padding: 0 10px 40px;
            }
        }

        .card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            position: relative;
        }

        .card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.1);
        }

        .card-img-wrapper {
            width: 100%;
            aspect-ratio: 16 / 9;
            background: #eee;
            position: relative;
            cursor: pointer;
        }

        .card img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            display: block;
            transition: transform 0.5s ease;
        }

        .card:hover img {
            transform: scale(1.03);
        }

        .card-content {
            padding: 25px;
        }

        .card-category {
            font-size: 14px;
            color: #4A90E2;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 10px;
        }

        .card-title {
            font-size: 20px;
            font-weight: 700;
            margin: 0 0 15px 0;
            line-height: 1.4;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .card-title a:hover {
            color: #4A90E2;
            text-decoration: underline;
        }

        .card-source {
            font-size: 14px;
            color: #888;
        }

        .card-source a {
            color: #4A90E2;
            text-decoration: none;
        }

        .card-source a:hover {
            text-decoration: underline;
        }

        /* Modal for Image Maximize */
        .modal {
            display: none;
            position: fixed;
            z-index: 1000;
            padding-top: 50px;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0, 0, 0, 0.9);
            backdrop-filter: blur(5px);
        }

        .modal-content {
            margin: auto;
            display: block;
            max-width: 90%;
            max-height: 90vh;
            object-fit: contain;
            animation-name: zoom;
            animation-duration: 0.3s;
        }

        @keyframes zoom {
            from {
                transform: scale(0.9)
            }

            to {
                transform: scale(1)
            }
        }

        .close {
            position: absolute;
            top: 15px;
            right: 35px;
            color: #fff;
            font-size: 40px;
            font-weight: bold;
            transition: 0.3s;
            cursor: pointer;
        }

        .close:hover,
        .close:focus {
            color: #bbb;
            text-decoration: none;
        }
    </style>
</head>

<body>

    <header>
        <h1>Daily Tech Briefing</h1>
        <p>Latest summaries from <%= new Date().toLocaleDateString('ja-JP') %>
        </p>
    </header>

    <div class="container">
        <div class="grid">
            <% for (const item of slides) { %>
                <div class="card">
                    <div class="card-img-wrapper" onclick="openModal('images/<%= item.imageFile %>')">
                        <img src="images/<%= item.imageFile %>" alt="<%= item.category %> Slide">
                    </div>
                    <div class="card-content">
                        <div class="card-category">
                            <%= item.category %>
                        </div>
                        <h3 class="card-title">
                            <a href="<%= item.sourceUrl %>" target="_blank"
                                style="color: inherit; text-decoration: none;">
                                <%= item.title %>
                            </a>
                        </h3>
                        <div class="card-source">Source: <a href="<%= item.sourceUrl %>" target="_blank">
                                <%= item.sourceName %>
                            </a></div>
                    </div>
                </div>
                <% } %>
        </div>
    </div>

    <!-- The Modal -->
    <div id="imageModal" class="modal" onclick="closeModal()">
        <span class="close">&times;</span>
        <img class="modal-content" id="modalImg">
    </div>

    <script>
        var modal = document.getElementById("imageModal");
        var modalImg = document.getElementById("modalImg");

        function openModal(imgSrc) {
            modal.style.display = "block";
            modalImg.src = imgSrc;
            document.body.style.overflow = "hidden"; // Prevent scrolling
        }

        function closeModal() {
            modal.style.display = "none";
            document.body.style.overflow = "auto";
        }

        // Close on Escape key
        document.addEventListener('keydown', function (event) {
            if (event.key === "Escape") {
                closeModal();
            }
        });
    </script>

</body>

</html>